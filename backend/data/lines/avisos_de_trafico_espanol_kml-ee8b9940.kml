		<SimpleData name="titulo">Pechada ao tráfico a rúa FONDO(CMÑO) Nº 18 (CASTRELOS) , entre o cruzamento con Camiño Pousa e Camiño da Falcoa</SimpleData>
		<SimpleData name="lon">-8.7247515535235</SimpleData>
		<SimpleData name="data_publicacion">12-03-2026</SimpleData>
